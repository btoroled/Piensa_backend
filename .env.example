# Variables de entorno de Piensa backend.
# Copia este archivo a `.env` y ajusta los valores.
# El servidor NO arranca si falta una variable requerida (ver src/config/env.ts).

# --- Requeridas ---
# Cadena de conexión a PostgreSQL. Requerida por la app y por `prisma validate`
# (sin ella prisma falla con P1012). Coincide con docker-compose.dev.yml.
DATABASE_URL="postgresql://piensa:piensa@localhost:5432/piensa_dev?schema=public"

# Secreto de firma del access token JWT (HS256). Requerido: mínimo 16 caracteres.
# En producción usar un valor aleatorio largo (p. ej. `openssl rand -base64 48`).
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"

# --- Opcionales (tienen valor por defecto) ---
# Entorno de ejecución: development | test | production. Default: development.
NODE_ENV=development

# Puerto HTTP de la API. Default: 3000.
PORT=3000

# Cadena de conexión a la base de datos separada de tests (misma instancia,
# base `piensa_test` creada por docker/postgres/init). La usa la suite / CI.
DATABASE_URL_TEST="postgresql://piensa:piensa@localhost:5432/piensa_test?schema=public"

# --- Cloudflare R2 (opcional; requerido solo para subir archivos, ISSUE-17) ---
# Sin estas variables la app arranca igual y POST /admin/uploads responde un
# error de configuración. En producción, setear las requeridas y funciona sin
# cambios de código.
# R2_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
# R2_BUCKET="piensa"
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_PUBLIC_BASE_URL=""   # base pública/CDN para lecturas (se usa en ISSUE-21)
